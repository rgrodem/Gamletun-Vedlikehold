# Kopier til .env.local for lokal utvikling. I produksjon legges disse inn i
# Vercel: Project -> Settings -> Environment Variables.

# Supabase (finnes i Supabase Dashboard -> Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://<prosjekt>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-nokkel>

# Service-rolle (Dashboard -> Settings -> API -> service_role).
# Brukes KUN server-side: e-postvarsler og cron-påminnelser.
SUPABASE_SERVICE_ROLE_KEY=<service-role-nokkel>

# Resend (resend.com -> API Keys)
RESEND_API_KEY=<resend-api-nokkel>

# Avsenderadresse. La stå tom for å bruke Resend sin testavsender
# (onboarding@resend.dev) — da leveres e-post kun til Resend-kontoens egen
# adresse. Sett til f.eks. 'Gamletun <varsel@gamletun.no>' når domenet er
# verifisert i Resend.
EMAIL_FROM=

# Hvem som får feilvarsler og den daglige vedlikeholdspåminnelsen.
NOTIFY_EMAIL=

# Hemmelighet som beskytter cron-endepunktet. Vercel sender den automatisk
# som Authorization-header når variabelen er satt. Generer en tilfeldig
# streng, f.eks. med: openssl rand -hex 32
CRON_SECRET=
