# Kopier til .env.local for lokal utvikling. I produksjon legges disse inn i
# Vercel: Project -> Settings -> Environment Variables.

# Supabase (finnes i Supabase Dashboard -> Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://<prosjekt>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-nokkel>

# Service-rolle (Dashboard -> Settings -> API -> service_role).
# Brukes KUN server-side: e-postvarsler og cron-påminnelser.
SUPABASE_SERVICE_ROLE_KEY=<service-role-nokkel>

# Resend (resend.com -> API Keys)
RESEND_API_KEY=<resend-api-nokkel>

# Avsenderadresse. La stå tom for å bruke Resend sin testavsender
# (onboarding@resend.dev) — da leveres e-post kun til Resend-kontoens egen
# adresse. Sett til f.eks. 'Gamletun <varsel@gamletun.no>' når domenet er
# verifisert i Resend.
EMAIL_FROM=

# Svar-til-adresse for utgående e-post (f.eks. invitasjoner). Når mottaker
# svarer, går svaret hit. Faller tilbake til 'rune@gamletun.no' for invitasjoner.
EMAIL_REPLY_TO=

# Hvem som får feilvarsler og den daglige vedlikeholdspåminnelsen.
NOTIFY_EMAIL=

# Hvem som får varsel ved nye reservasjoner (faller tilbake til NOTIFY_EMAIL
# hvis tom).
RESERVATION_NOTIFY_EMAIL=

# Hemmelighet som beskytter cron-endepunktet. Vercel sender den automatisk
# som Authorization-header når variabelen er satt. Generer en tilfeldig
# streng, f.eks. med: openssl rand -hex 32
CRON_SECRET=

# Statens Vegvesen — API-nøkkel for kjøretøyoppslag (tekniske data).
# Brukes server-side i /api/vehicle-lookup. Legg ALDRI nøkkelen i koden.
SVV_API_KEY=
# Valgfri overstyring av endepunkt (standard fungerer normalt):
# SVV_API_URL=https://akfell-datautlevering.atlas.vegvesen.no/enkeltoppslag/kjoretoydata

# --- Fase 1 ---------------------------------------------------------------

# Claude (Anthropic) — KI-funksjoner: dokument-parsing, feildiagnose,
# triagering. Brukes KUN server-side. Hent på console.anthropic.com.
ANTHROPIC_API_KEY=

# Gårdens koordinater for værvarsel (MET/yr.no). Maks 4 desimaler.
# Standard er Sandnes-området hvis tomt.
FARM_LAT=58.8524
FARM_LON=5.7352

# Web-push (PWA-varsler). Generer ett nøkkelpar med:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:post@gamletun.no

# --- Tilgang / white-label ------------------------------------------------

# Tillatt e-postdomene for magic-link/OAuth-innlogging via /auth/callback.
# Inviterte brukere (admin -> Brukere -> Inviter) slipper alltid inn uansett
# domene, så dette gjelder kun selvbetjent innlogging. Standard: @gamletun.no
AUTH_ALLOW_DOMAIN=@gamletun.no

# Ekstra enkeltadresser som får tilgang (kommaseparert), f.eks. eier.
AUTH_ALLOW_EMAILS=

# Appnavn brukt i invitasjons-e-post (og senere white-label). Standard:
# "Gamletun Vedlikehold".
NEXT_PUBLIC_APP_NAME=Gamletun Vedlikehold
